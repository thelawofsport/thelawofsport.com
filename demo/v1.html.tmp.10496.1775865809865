/* Portal Layout */
.portal-page { display: flex; min-height: 100vh; padding-top: 56px; }

/* Portal Top Nav */
.portal-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: 56px;
    background: var(--color-navy); display: flex; align-items: center;
    justify-content: space-between; padding: 0 24px;
}
.portal-nav-left { display: flex; align-items: center; gap: 24px; }
.portal-nav-left .logo-text { font-size: 1rem; }
.portal-nav-menu { display: flex; gap: 4px; }
.portal-nav-menu a {
    color: rgba(255,255,255,0.7); font-size: 0.84rem; font-weight: 500;
    padding: 6px 14px; border-radius: var(--radius-sm); transition: all var(--transition);
}
.portal-nav-menu a:hover, .portal-nav-menu a.active {
    color: var(--color-white); background: rgba(255,255,255,0.1);
}
.portal-nav-right { display: flex; align-items: center; gap: 16px; }
.portal-search {
    display: flex; align-items: center; background: rgba(255,255,255,0.1);
    border-radius: var(--radius-sm); padding: 6px 12px; gap: 8px;
}
.portal-search input {
    background: transparent; border: none; color: var(--color-white);
    font-family: var(--font-sans); font-size: 0.84rem; outline: none; width: 180px;
}
.portal-search input::placeholder { color: rgba(255,255,255,0.4); }
.search-icon { color: rgba(255,255,255,0.4); font-size: 0.9rem; }

/* Dark Mode Toggle */
.theme-toggle {
    background: rgba(255,255,255,0.1); border: none; color: rgba(255,255,255,0.7);
    width: 34px; height: 34px; border-radius: 50%; cursor: pointer; font-size: 1rem;
    display: flex; align-items: center; justify-content: center; transition: all var(--transition);
}
.theme-toggle:hover { background: rgba(255,255,255,0.2); color: var(--color-white); }

/* AI Assistant Button */
.ai-assistant-btn {
    background: linear-gradient(135deg, rgba(91,45,142,0.6), rgba(27,122,90,0.6));
    border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.85);
    width: 34px; height: 34px; border-radius: 50%; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all var(--transition); position: relative;
}
.ai-assistant-btn:hover {
    background: linear-gradient(135deg, rgba(91,45,142,0.85), rgba(27,122,90,0.85));
    color: var(--color-white); border-color: rgba(255,255,255,0.4);
    box-shadow: 0 0 12px rgba(91,45,142,0.4);
}
.ai-assistant-btn svg { width: 16px; height: 16px; }

/* Left Sidebar */
.portal-sidebar {
    width: 220px; background: var(--color-bg-alt); border-right: 1px solid var(--color-border);
    padding: 24px 0; flex-shrink: 0; position: sticky; top: 56px;
    height: calc(100vh - 56px); overflow-y: auto;
}
.sidebar-section { padding: 0 16px; margin-bottom: 28px; }
.sidebar-label {
    font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--color-text-light); margin-bottom: 8px; padding: 0 8px;
}
.sidebar-link {
    display: flex; align-items: center; gap: 10px; padding: 8px 12px;
    border-radius: var(--radius-sm); color: var(--color-text); font-size: 0.88rem;
    font-weight: 500; transition: all var(--transition);
}
.sidebar-link:hover { background: var(--color-border); color: var(--color-text); }
.sidebar-link.active { background: var(--color-emerald-pale); color: var(--color-emerald); font-weight: 600; }
[data-theme="dark"] .sidebar-link.active { background: rgba(27,122,90,0.2); }
.sidebar-icon { font-size: 1rem; width: 20px; text-align: center; }
.sidebar-divider { height: 1px; background: var(--color-border); margin: 0 16px 28px; }
.sidebar-link { position: relative; }
.sidebar-badge {
    position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
    min-width: 18px; height: 18px; border-radius: 9px;
    background: #E53E3E; color: #FFFFFF; font-size: 0.65rem; font-weight: 700;
    display: flex; align-items: center; justify-content: center; padding: 0 5px;
    line-height: 1; box-shadow: 0 1px 3px rgba(229,62,62,0.4);
}

/* Main Content Area */
.portal-main { flex: 1; padding: 32px 40px; min-width: 0; }

/* University Banner */
.uni-banner {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-md); padding: 14px 20px; margin-bottom: 28px;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
}
.uni-banner-text { font-size: 0.88rem; color: var(--color-text-light); }
.uni-banner-text strong { color: var(--color-text); font-weight: 600; }
.uni-banner-link { font-size: 0.82rem; font-weight: 600; color: var(--color-emerald); white-space: nowrap; }

/* Home Layout Grid */
.home-grid { display: grid; grid-template-columns: 1fr 300px; gap: 32px; }

/* Announcements */
.announcement-card {
    background: linear-gradient(135deg, var(--color-navy), var(--color-navy-mid));
    border-radius: var(--radius-md); padding: 20px 24px; margin-bottom: 12px; color: var(--color-white);
}
.announcement-date { font-size: 0.75rem; color: var(--color-gold-light); font-weight: 600; margin-bottom: 4px; }
.announcement-title { font-size: 1rem; font-weight: 600; margin-bottom: 4px; }
.announcement-text { font-size: 0.88rem; color: rgba(255,255,255,0.75); line-height: 1.5; }

/* Calendar Widget */
.calendar-widget {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-md); padding: 20px;
}
.calendar-widget h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 16px; color: var(--color-navy); }
[data-theme="dark"] .calendar-widget h3 { color: var(--color-white); }
.calendar-item {
    display: flex; gap: 12px; padding: 10px 0;
    border-bottom: 1px solid var(--color-border); align-items: flex-start;
}
.calendar-item:last-child { border-bottom: none; }
.cal-date {
    flex-shrink: 0; width: 44px; height: 44px; background: var(--color-emerald-pale);
    border-radius: var(--radius-sm); display: flex; flex-direction: column;
    align-items: center; justify-content: center; line-height: 1;
}
[data-theme="dark"] .cal-date { background: rgba(27,122,90,0.2); }
.cal-month { font-size: 0.6rem; font-weight: 700; color: var(--color-emerald); text-transform: uppercase; }
.cal-day { font-size: 1rem; font-weight: 700; color: var(--color-emerald); }
.cal-info { flex: 1; }
.cal-title { font-size: 0.85rem; font-weight: 600; color: var(--color-text); }
.cal-type { font-size: 0.72rem; font-weight: 600; color: var(--color-emerald); text-transform: uppercase; letter-spacing: 0.04em; }
.cal-type.assessment { color: var(--color-gold); }

/* Section Heading */
.portal-section-heading { font-family: var(--font-serif); font-size: 1.4rem; color: var(--color-navy); margin-bottom: 20px; }
[data-theme="dark"] .portal-section-heading { color: var(--color-white); }

/* Module Tiles */
.module-tiles-section { margin-top: 40px; }
.module-tiles-section h2 { font-family: var(--font-serif); font-size: 1.4rem; color: var(--color-navy); margin-bottom: 20px; }
[data-theme="dark"] .module-tiles-section h2 { color: var(--color-white); }
.tile-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.module-tile {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-md); padding: 24px 20px; transition: all var(--transition);
    cursor: pointer; text-decoration: none; display: block;
}
.module-tile:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); border-color: var(--color-emerald); }
.tile-module-num { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-emerald); margin-bottom: 6px; }
.module-tile h4 { font-size: 0.95rem; font-weight: 700; color: var(--color-navy); margin-bottom: 6px; }
[data-theme="dark"] .module-tile h4 { color: var(--color-white); }
.module-tile p { font-size: 0.8rem; color: var(--color-text-light); line-height: 1.5; }
.tile-locked { opacity: 0.5; pointer-events: none; }
.tile-locked::after { content: '\1F512'; display: block; margin-top: 8px; font-size: 0.8rem; }
.tile-welcome {
    background: linear-gradient(135deg, var(--color-emerald), var(--color-emerald-light));
    border-color: var(--color-emerald); color: var(--color-white);
}
.tile-welcome h4 { color: var(--color-white); }
.tile-welcome p { color: rgba(255,255,255,0.85); }
.tile-welcome .tile-module-num { color: var(--color-gold-light); }

/* Hero Banner Strip */
.hero-banner {
    position: relative; overflow: hidden; height: 180px;
    background: var(--color-navy); margin-bottom: 28px; border-radius: var(--radius-md);
}
.hero-banner-bg {
    position: absolute; inset: 0; opacity: 0.25;
    background:
        url('https://images.unsplash.com/photo-1461896836934-bd45ba8fcfc7?w=1200&q=80') center/cover no-repeat;
}
[data-theme="dark"] .hero-banner-bg { opacity: 0.15; }
.hero-banner-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(11,29,58,0.85) 0%, rgba(26,58,107,0.7) 50%, rgba(11,29,58,0.85) 100%);
}
.hero-banner-content {
    position: relative; z-index: 2; height: 100%;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 0 24px;
}
.hero-banner-title {
    font-family: var(--font-sans); font-size: 3rem; font-weight: 800;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-white);
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
}
.hero-banner-title span { color: var(--color-gold); }
.hero-banner-sub {
    font-size: 0.9rem; color: rgba(255,255,255,0.65); margin-top: 6px;
    font-weight: 400; letter-spacing: 0.06em;
}
.hero-banner-accents {
    position: absolute; inset: 0; z-index: 1; pointer-events: none; overflow: hidden;
}
.hero-accent-line {
    position: absolute; height: 2px; background: var(--color-gold); opacity: 0.3;
}
.hero-accent-line:nth-child(1) { top: 30px; left: -20px; width: 120px; transform: rotate(-8deg); }
.hero-accent-line:nth-child(2) { bottom: 40px; right: -10px; width: 160px; transform: rotate(5deg); }
.hero-accent-line:nth-child(3) { top: 50%; left: 10%; width: 80px; transform: rotate(-3deg); opacity: 0.15; }
/* Sports icon silhouettes */
.hero-sport-icon {
    position: absolute; font-size: 2.5rem; opacity: 0.07; color: var(--color-white);
}
.hero-sport-icon:nth-child(4) { top: 20px; left: 8%; }
.hero-sport-icon:nth-child(5) { bottom: 15px; left: 25%; }
.hero-sport-icon:nth-child(6) { top: 25px; right: 12%; }
.hero-sport-icon:nth-child(7) { bottom: 20px; right: 8%; }
.hero-sport-icon:nth-child(8) { top: 50%; right: 30%; transform: translateY(-50%); }

/* Portal Footer */
.portal-footer {
    border-top: 1px solid var(--color-border); padding: 20px 0; margin-top: 48px;
    font-size: 0.78rem; color: var(--color-text-light);
    display: flex; justify-content: space-between; align-items: center;
}
.portal-footer a { font-size: 0.78rem; }

/* Responsive */
@media (max-width: 900px) {
    .home-grid { grid-template-columns: 1fr; }
    .tile-grid { grid-template-columns: repeat(2, 1fr); }
    .portal-sidebar { display: none; }
    .portal-main { padding: 24px 20px; }
}
@media (max-width: 600px) { .tile-grid { grid-template-columns: 1fr; } }
    </style>
