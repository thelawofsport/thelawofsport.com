    <script>
        // Dark mode toggle
        const toggle = document.getElementById('themeToggle');
        const html = document.documentElement;

        // Check saved preference
        if (localStorage.getItem('theme') === 'dark') {
            html.setAttribute('data-theme', 'dark');
            toggle.textContent = '☀';
        }

        toggle.addEventListener('click', () => {
            const isDark = html.getAttribute('data-theme') === 'dark';
            if (isDark) {
                html.removeAttribute('data-theme');
                localStorage.setItem('theme', 'light');
                toggle.textContent = '☾';
            } else {
                html.setAttribute('data-theme', 'dark');
                localStorage.setItem('theme', 'dark');
                toggle.textContent = '☀';
            }
        });

        // Simple search highlight (placeholder functionality)
        const searchInput = document.getElementById('searchInput');
        searchInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                const query = searchInput.value.trim().toLowerCase();
                if (!query) return;
                // In production, this would search across all pages
                alert('Search for: "' + searchInput.value + '"\n\nFull search functionality will be connected when content is populated.');
            }
        });
    </script>

